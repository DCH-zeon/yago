# ╔════════════════════════════════════════════════════╗
# ║        YAGO REST API - Environment Variables       ║
# ╠====================================================╣
#
#   Copy this file to .env and set your values
#
#   CONFIGURATION PRIORITY (highest to lowest):
#   1. Environment variables (.env file) - THIS FILE
#   2. Environment-specific config (config.production.yaml, etc.)
#   3. Base configuration (config.yaml)
#
#   💡 For ALL available configuration options, see: api/configs/config.yaml
#   📍 Most defaults are in config files - only override what you need here
#
# ╚════════════════════════════════════════════════════╝

# ╔════════════════════════════════════════════════════╗
# ║      YAGO REST API Version (for Docker Compose)    ║
# ╚════════════════════════════════════════════════════╝
VERSION=1.0.0

# ╔════════════════════════════════════════════════════╗
# ║                 Application version                ║
# ╚════════════════════════════════════════════════════╝
APP_VERSION=1.0.0

# ╔════════════════════════════════════════════════════╗
# ║                ENVIRONMENT SELECTION               ║
# ╚════════════════════════════════════════════════════╝
APP_ENVIRONMENT=development        # development | staging | production

# ╔════════════════════════════════════════════════════╗
# ║           SECURITY: JWT SECRET (REQUIRED)          ║
# ╚════════════════════════════════════════════════════╝
# Security Requirements:
# Minimum 32 characters (64+ for production)
#
# Auto-generation (recommended):
#   make quick-start          # Automatically generates if missing
#   make generate-jwt-secret  # Manual generation with examples
#
JWT_SECRET=

# Token expiration (optional - defaults are secure)
# JWT_ACCESS_TOKEN_TTL=15m         # Access token TTL (default: 15 minutes)
# JWT_REFRESH_TOKEN_TTL=168h       # Refresh token TTL (default: 7 days)

# ╔════════════════════════════════════════════════════╗
# ║                      DATABASE                      ║
# ╚════════════════════════════════════════════════════╝
DATABASE_PASSWORD=secret           # ⚠️ Required: Database password
DATABASE_HOST=postgres             # Override database host
# DATABASE_PORT=5432               # Override database port
DATABASE_USER=app                  # Override database user
DATABASE_NAME=yago                 # Override database name
DATABASE_SSLMODE=disable           # Override SSL mode (disable|require|verify-full)

# ╔════════════════════════════════════════════════════╗
# ║                       REDIS                        ║
# ╚════════════════════════════════════════════════════╝
# REDIS_PORT=6379                    # Override Redis port
# REDIS_HOST=redis                   # Override Redis host
# REDIS_PASSWORD=                    # Override Redis password

# ╔════════════════════════════════════════════════════╗
# ║                      RABBITMQ                      ║
# ╚════════════════════════════════════════════════════╝
RABBITMQ_PASSWORD=secret                 # ⚠️ Required: RabbitMQ password
# RABBITMQ_PORT=5672                     # Override RabbitMQ port
# RABBITMQ_MANAGEMENT_PORT=15672         # Override RabbitMQ management port
# RABBITMQ_HOST=rabbitmq-yago            # Override RabbitMQ host
# RABBITMQ_USER=yago                     # Override RabbitMQ user

# ╔════════════════════════════════════════════════════╗
# ║                      CENTRIFUGO                    ║
# ╚════════════════════════════════════════════════════╝
CENTRIFUGO_PASSWORD=secret                   # ⚠️ Required: Centrifugo password
# CENTRIFUGO_PORT=8000                       # Override Centrifugo port
# CENTRIFUGO_HOST=centrifugo                 # Override Centrifugo host
# CENTRIFUGO_USER=yago                       # Override Centrifugo user

# ╔════════════════════════════════════════════════════╗
# ║                      MINIO S3                      ║
# ╚════════════════════════════════════════════════════╝
# MINIO_ROOT_PASSWORD=tJusX1DMQ0w            # ⚠️ Required: Minio password
MINIO_MAIN_PORT=9002                         # Override Minio main port
MINIO_CONSOLE_PORT=9001                      # Override Minio console port
# MINIO_ROOT_USER=root                       # Override Minio user

# ╔════════════════════════════════════════════════════╗
# ║    COMMON OVERRIDES (optional - uncomment to use)  ║
# ╚════════════════════════════════════════════════════╝
SERVER_PORT=9009                   # Override server port
DOMAIN=yago.loc                    # Override domain
# LOGGING_LEVEL=debug              # Override for verbose logging

# ╔════════════════════════════════════════════════════╗
# ║             RATE LIMITING CONFIGURATION            ║
# ╚════════════════════════════════════════════════════╝
RATELIMIT_ENABLED=true
RATELIMIT_REQUESTS=100
RATELIMIT_WINDOW=1m

# ╔════════════════════════════════════════════════════╗
# ║         CONTAINER NAMES (for docker-compose)       ║
# ╚════════════════════════════════════════════════════╝
DOCKER_GROUP_NAME=yago-app                    # Override Docker group name
NGINX_CONTAINER_NAME=yago-nginx               # Override NGINX container name
APP_CONTAINER_NAME=yago-api                   # Override API container name
ADMIN_CONTAINER_NAME=yago-admin               # Override ADMIN container name
NODE_CONTAINER_NAME=yago-node                 # Override NodeJS container name
DATABASE_CONTAINER_NAME=yago-postgres         # Override database container name
REDIS_CONTAINER_NAME=yago-redis               # Override Redis container name
RABBITMQ_CONTAINER_NAME=yago-rabbitmq         # Override RabbitMQ container name
CENTRIFUGO_CONTAINER_NAME=yago-centrifugo     # Override Centrifugo container name
MINIO_CONTAINER_NAME=yago-minio               # Override MinIO container name

APP_CONTAINER_NAME_PROD=yago-api_prod         # Override API container name (production)
DATABASE_CONTAINER_NAME_PROD=yago-db_prod     # Override database container name (production)
REDIS_CONTAINER_NAME_PROD=yago-redis_prod     # Override Redis container name (production)

# ╔════════════════════════════════════════════════════╗
# ║  HEALTH CHECK CONFIGURATION (for docker-compose)   ║
# ╚════════════════════════════════════════════════════╝
HEALTH_CHECK_INTERVAL=15s
HEALTH_CHECK_TIMEOUT=10s
HEALTH_CHECK_RETRIES=6
HEALTH_CHECK_START_PERIOD=20s
