# 💡 Copy this file to .env and set your values

APP_NAME=YAGO
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://admin.yago.loc
VITE_DEV_SERVER_URL=http://localhost:5173

APP_LOCALE=uk
APP_FALLBACK_LOCALE=uk
APP_FAKER_LOCALE=uk-UA

# ┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓
# ┃              Default Credential !!!                ┃
# ┡━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┩
ADMIN_LOGIN="admin@mail.com"
ADMIN_PASSWORD="secret856"
# └────────────────────────────────────────────────────┘

APP_MAINTENANCE_DRIVER=cache
APP_MAINTENANCE_STORE=redis
# PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# ┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓
# ┃                      DATABASE                      ┃
# ┡━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┩
DB_CONNECTION_API=yago
DB_HOST_API=postgres
DB_PORT_API=5432
DB_DATABASE_API=yago
DB_USERNAME_API=app
DB_PASSWORD_API=secret

DB_CONNECTION_ADMIN=admin
DB_HOST_ADMIN=postgres
DB_PORT_ADMIN=5432
DB_DATABASE_ADMIN=admin
DB_USERNAME_ADMIN=app
DB_PASSWORD_ADMIN=secret
# └────────────────────────────────────────────────────┘

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓
# ┃                       REDIS                        ┃
# ┡━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┩
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379
# └────────────────────────────────────────────────────┘

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓
